# 2D_Default — textured-sprite shader with the "egg" transparency reveal.
# Where: engine default for the Font, Iface, Generic, Critter and Rain QuadSprite draw slots (the main textured-sprite shader); includes the "egg" transparency reveal that fades sprites occluding a focal point.
# How: vertex transforms the sprite by the projection matrix and forwards colour, UV, egg flags and screen position; fragment samples MainTex, multiplies by vertex colour with a 2x brightness scale, and where the egg flag is set scales alpha by a radial falloff around the egg centre so occluding sprites fade out; near-zero alpha is discarded. Depth test LessEqual.
# Depth: writes depth (so direct-draw 3D models and in-scene particles occlude against sprites) but does
# NOT test it (DepthFunc = Always) — standing map sprites all share one depth gradient, so their depth
# planes are parallel and never intersect, which makes the painter order by screen row exactly equivalent
# to a per-pixel depth test while being immune to the interpolation noise that made coincident planes
# z-fight in horizontal stripes. Draw order is authoritative for sprite-vs-sprite occlusion; see
# MapSpriteList::MakeDrawOrderPos and Docs/FrontendAndRendering.md.
# Profile: minimal — targets the lowest D3D feature level (no gl_FragCoord/derivative/dynamic-indexing features) so it runs on the weakest hardware; embedding projects override with richer copies where needed.

[Effect]
DepthFunc = Always

[VertexShader]
layout(set = 0, binding = 0, std140) uniform ProjBuf { mat4 ProjMatrix; };

layout(location = 0) in vec3 InPosition;
layout(location = 1) in vec4 InColor;
layout(location = 2) in vec2 InTexCoord;
layout(location = 3) in vec2 InEggData;

layout(location = 0) out vec4 Color;
layout(location = 1) out vec2 TexCoord;
layout(location = 2) out vec2 EggFlag;
layout(location = 3) out vec2 ScreenPos;

void main(void)
{
    gl_Position = ProjMatrix * vec4(InPosition, 1.0);
    Color = InColor;
    TexCoord = InTexCoord;
    EggFlag = InEggData;
    ScreenPos = InPosition.xy;
}

[FragmentShader]
layout(set = 1, binding = 0) uniform sampler2D MainTex;
layout(set = 0, binding = 1, std140) uniform EggBuf { vec4 EggData[3]; };

layout(location = 0) in vec4 Color;
layout(location = 1) in vec2 TexCoord;
layout(location = 2) in vec2 EggFlag;
layout(location = 3) in vec2 ScreenPos;

layout(location = 0) out vec4 FragColor;

const float AlphaDepthCutoff = 1.0 / 255.0;

float GetEggAlpha(vec4 eggData, float transitionStart)
{
    vec2 eggCoord = (ScreenPos - eggData.xy) / eggData.zw;
    float radialAlpha = clamp(dot(eggCoord, eggCoord), 0.0, 1.0);
    return radialAlpha <= transitionStart ? 0.0 : (radialAlpha - transitionStart) / (1.0 - transitionStart);
}

void main(void)
{
    vec4 texColor = texture(MainTex, TexCoord);
    float transitionStart = clamp(EggData[2].x, 0.0, 0.9999);
    FragColor.rgb = (texColor.rgb * Color.rgb) * 2.0;
    FragColor.a = texColor.a * Color.a;
    if (EggFlag.x > 0.0 && EggData[0].z > 0.0 && EggData[0].w > 0.0) {
        FragColor.a *= GetEggAlpha(EggData[0], transitionStart);
    }
    if (EggFlag.y > 0.0 && EggData[1].z > 0.0 && EggData[1].w > 0.0) {
        FragColor.a *= GetEggAlpha(EggData[1], transitionStart);
    }
    if (FragColor.a <= AlphaDepthCutoff) {
        discard;
    }
}
